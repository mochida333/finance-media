---
import BlogPost from "../../../../layouts/BlogPost.astro";
import Pagination from "../../../../components/Pagination.astro";
import { getBlogs, getCategories, getCategoryDetail } from "../../../../library/microcms";
import type { Blog } from "../../../../library/microcms";
import PostCard from "../../../../components/PostCard.astro";

const PER_PAGE = 9;

export async function getStaticPaths() {
  const perPage = 9;

  const categoryIds: string[] = [];
  let offset = 0;
  while (true) {
    const res = await getCategories({ fields: ["id"], limit: 100, offset });
    categoryIds.push(...res.contents.map((c) => c.id));
    offset += res.limit;
    if (offset >= res.totalCount) break;
  }

  const paths: Array<{ params: { id: string; page: string } }> = [];

  for (const id of categoryIds) {
    const filters = `category[equals]${id}[or]category[contains]${id}`;
    const res = await getBlogs({ fields: ["id"], filters, limit: 1, offset: 0 });
    const totalPages = Math.ceil(res.totalCount / perPage);
    for (let page = 2; page <= totalPages; page++) {
      paths.push({ params: { id, page: String(page) } });
    }
  }

  return paths;
}

const { id, page: pageParam } = Astro.params;
const page = Number(pageParam);
if (!id) throw new Error("Missing route param: id");
if (!Number.isFinite(page) || page < 2) throw new Error(`Invalid page param: ${pageParam}`);

const category = await getCategoryDetail(id, { fields: ["id", "name"] });

const filters = `category[equals]${id}[or]category[contains]${id}`;
const response = await getBlogs({
  fields: ["id", "title", "eyecatch", "publishedAt", "category"],
  depth: 1,
  filters,
  limit: PER_PAGE,
  offset: (page - 1) * PER_PAGE,
});

const totalPages = Math.ceil(response.totalCount / PER_PAGE);
const posts = response.contents as Blog[];
---

<BlogPost
  title={`カテゴリ: ${category.name ?? category.id} (ページ ${page})`}
  description="andco finance"
  pubDate={new Date()}
>
  <main>
    <ul class="grid">
      {posts.map((post) => {
        return (
          <PostCard
            id={post.id}
            title={post.title}
            eyecatchUrl={post.eyecatch?.url}
            publishedAt={post.publishedAt}
            category={post.category}
          />
        );
      })}
    </ul>

    <Pagination currentPage={page} totalPages={totalPages} basePath={`/category/${id}`} />
  </main>
</BlogPost>

<style>
  main {
    margin: auto;
    padding: 1em;
    width: 1200px;
    max-width: 100%;
    box-sizing: border-box;
  }
  .grid {
    width: stretch;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    padding: 0;
    margin: 0;
  }

  @media (max-width: 768px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>

