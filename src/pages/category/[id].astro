---
import BlogPost from "../../layouts/BlogPost.astro";
import Pagination from "../../components/Pagination.astro";
import { buildCategoryFilters, getCategoryIds, getCategoryLabel, getPostCards } from "../../library/cms";
import PostCard from "../../components/PostCard.astro";

const PER_PAGE = 9;

export async function getStaticPaths() {
  const ids = await getCategoryIds();
  return ids.map((id) => ({ params: { id } }));
}

const { id } = Astro.params;
if (!id) throw new Error("Missing route param: id");

const categoryLabel = await getCategoryLabel(id);

const filters = buildCategoryFilters(id);
const response = await getPostCards({ filters, limit: PER_PAGE, offset: 0 });

const totalPages = Math.ceil(response.totalCount / PER_PAGE);

const posts = response.cards;
---

<BlogPost title={`カテゴリ: ${categoryLabel}`} description="andco finance" pubDate={new Date()}>
  <main>
    <ul class="grid">
      {posts.map((post) => {
        return (
          <PostCard
            id={post.id}
            title={post.title}
            eyecatchUrl={post.eyecatchUrl}
            publishedAt={post.publishedAt}
            category={post.categories}
          />
        );
      })}
    </ul>
    <Pagination currentPage={1} totalPages={totalPages} basePath={`/category/${id}`} />
  </main>
</BlogPost>

<style>
  main {
    margin: auto;
    padding: 1em;
    width: 1200px;
    max-width: 100%;
    box-sizing: border-box;
  }
  .grid {
    width: stretch;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    padding: 0;
    margin: 0;
  }

  @media (max-width: 768px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>

