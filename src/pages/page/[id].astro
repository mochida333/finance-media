---
import BlogPost from "../../layouts/BlogPost.astro";
import { getPageDetail, getPageIdsSafe } from "../../library/cms";

export async function getStaticPaths() {
  const ids = await getPageIdsSafe();
  return ids.map((id) => ({ params: { id } }));
}

const { id } = Astro.params;
if (!id) {
  throw new Error("Missing route param: id");
}

const page = await getPageDetail(id);
---

<BlogPost
  title={page.title ?? page.id ?? "Page"}
  description={page.title ?? page.id ?? "Page"}
  pubDate={new Date()}
>
  <div class="body" set:html={page.contentHtml ?? ""} />
</BlogPost>

<style>
  .body :global(img) {
    max-width: 100%;
    height: auto;
  }
</style>

