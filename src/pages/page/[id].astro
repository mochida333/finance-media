---
import BlogPost from "../../layouts/BlogPost.astro";
import { getPageDetail, getPages } from "../../library/microcms";
import type { Page } from "../../library/microcms";

export async function getStaticPaths() {
  try {
    const ids: string[] = [];
    let offset = 0;
    const limit = 100;

    while (true) {
      const res = await getPages({ fields: ["id"], limit, offset });
      ids.push(...res.contents.map((c) => c.id));
      offset += res.limit;
      if (offset >= res.totalCount) break;
    }

    return ids.map((id) => ({ params: { id } }));
  } catch {
    // pages エンドポイント未作成/未設定でもビルドを壊さない
    return [];
  }
}

const { id } = Astro.params;
if (!id) {
  throw new Error("Missing route param: id");
}

const page: Page = await getPageDetail(id);
---

<BlogPost
  title={page.title ?? page.id ?? "Page"}
  description={page.title ?? page.id ?? "Page"}
  pubDate={new Date()}
>
  <div class="body" set:html={page.content ?? ""} />
</BlogPost>

<style>
  .body :global(img) {
    max-width: 100%;
    height: auto;
  }
</style>

