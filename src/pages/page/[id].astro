---
export const prerender = true;

import BlogPost from "../../layouts/BlogPost.astro";
import { getPageDetail, getPageIdsSafe } from "../../library/cms";

export async function getStaticPaths() {
  const ids = await getPageIdsSafe();
  return ids.map((id) => ({ params: { id } }));
}

const { id } = Astro.params;
if (!id) {
  throw new Error("Missing route param: id");
}

let page: Awaited<ReturnType<typeof getPageDetail>> | null = null;
try {
  page = await getPageDetail(id as string);
} catch {
  Astro.response.status = 404;
  page = null;
}
---

{page ? (
  <BlogPost
    title={page.title ?? page.id ?? "Page"}
    description={page.title ?? page.id ?? "Page"}
    pubDate={new Date()}
  >
    <div class="body" set:html={page.contentHtml ?? ""} />
  </BlogPost>
) : (
  <BlogPost title="Not Found" description="Not Found" pubDate={new Date()}>
    <div class="body">
      <h1>Not Found</h1>
      <p>ページが見つかりませんでした。</p>
    </div>
  </BlogPost>
)}

<style>
  .body :global(img) {
    max-width: 100%;
    height: auto;
  }
</style>

