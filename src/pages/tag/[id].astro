---
import BlogPost from "../../layouts/BlogPost.astro";
import { getBlogs, getTagDetail } from "../../library/microcms";
import type { Blog } from "../../library/microcms";
import Pagination from "../../components/Pagination.astro";
import PostCard from "../../components/PostCard.astro";

const PER_PAGE = 9;

export async function getStaticPaths() {
  function toTagId(t: unknown): string | null {
    if (!t) return null;
    if (typeof t === "string") return t;
    if (typeof t === "object") {
      const obj = t as { id?: string; name?: string };
      return obj.id ?? obj.name ?? null;
    }
    return null;
  }

  const tagIds = new Set<string>();
  let offset = 0;
  while (true) {
    const res = await getBlogs({
      fields: ["id", "tag", "tags"],
      depth: 1,
      limit: 100,
      offset,
    });

    for (const post of res.contents as any[]) {
      const rawFromTags = Array.isArray(post.tags) ? post.tags : post.tags ? [post.tags] : [];
      const rawFromTag = Array.isArray(post.tag) ? post.tag : post.tag ? [post.tag] : [];
      for (const t of [...rawFromTags, ...rawFromTag]) {
        const id = toTagId(t);
        if (id) tagIds.add(id);
      }
    }

    offset += res.limit;
    if (offset >= res.totalCount) break;
  }

  return Array.from(tagIds).map((id) => ({
    params: { id: encodeURIComponent(id) },
  }));
}


const rawParam = Astro.params.id;
if (!rawParam) throw new Error("Missing route param: id");
const id = decodeURIComponent(rawParam);
const idEncoded = encodeURIComponent(id);

const tag = await getTagDetail(id, { fields: ["name"] });

const filters = `tag[equals]${id}[or]tag[contains]${id}[or]tags[equals]${id}[or]tags[contains]${id}`;
const response = await getBlogs({
  fields: ["id", "title", "eyecatch", "publishedAt", "category"],
  depth: 1,
  filters,
  limit: PER_PAGE,
  offset: 0,
});

const totalPages = Math.ceil(response.totalCount / PER_PAGE);
const posts = response.contents as Blog[];
---

<BlogPost title={`タグ: ${tag.name ?? id}`} description="andco finance" pubDate={new Date()}>
  <main>
    <ul class="grid">
      {posts.map((post) => {
        return (
          <PostCard
            id={post.id}
            title={post.title}
            eyecatchUrl={post.eyecatch?.url}
            publishedAt={post.publishedAt}
            category={post.category}
          />
        );
      })}
    </ul>
    <Pagination currentPage={1} totalPages={totalPages} basePath={`/tag/${idEncoded}`} />
  </main>
</BlogPost>

<style>
  main {
    margin: auto;
    padding: 1em;
    width: 1200px;
    max-width: 100%;
    box-sizing: border-box;
  }
  .grid {
    width: stretch;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    padding: 0;
    margin: 0;
  }

  @media (max-width: 768px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>

