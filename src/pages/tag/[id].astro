---
import BlogPost from "../../layouts/BlogPost.astro";
import Pagination from "../../components/Pagination.astro";
import PostCard from "../../components/PostCard.astro";
import { buildTagFilters, collectTagIdsFromAllPosts, getPostCards, getTagNameSafe } from "../../library/cms";

const PER_PAGE = 9;

export async function getStaticPaths() {
  const tagIds = await collectTagIdsFromAllPosts();
  return tagIds.map((id) => ({ params: { id: encodeURIComponent(id) } }));
}


const rawParam = Astro.params.id;
if (!rawParam) throw new Error("Missing route param: id");
const id = decodeURIComponent(rawParam);
const idEncoded = encodeURIComponent(id);

const tagName = await getTagNameSafe(id);

const filters = buildTagFilters(id);
const response = await getPostCards({ filters, limit: PER_PAGE, offset: 0 });

const totalPages = Math.ceil(response.totalCount / PER_PAGE);
const posts = response.cards;
---

<BlogPost title={`タグ: ${tagName}`} description="andco finance" pubDate={new Date()}>
  <main>
    <ul class="grid">
      {posts.map((post) => {
        return (
          <PostCard
            id={post.id}
            title={post.title}
            eyecatchUrl={post.eyecatchUrl}
            publishedAt={post.publishedAt}
            category={post.categories}
          />
        );
      })}
    </ul>
    <Pagination currentPage={1} totalPages={totalPages} basePath={`/tag/${idEncoded}`} />
  </main>
</BlogPost>

<style>
  main {
    margin: auto;
    padding: 1em;
    width: 1200px;
    max-width: 100%;
    box-sizing: border-box;
  }
  .grid {
    width: stretch;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    padding: 0;
    margin: 0;
  }

  @media (max-width: 768px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>

