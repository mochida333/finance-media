---
export const prerender = true;

import BlogPost from '../../../../layouts/BlogPost.astro';
import Pagination from '../../../../components/Pagination.astro';
import PostCard from '../../../../components/PostCard.astro';
import { buildTagFilters, getPostCards, getTagIds, getTagNameSafe } from '../../../../library/cms';

const PER_PAGE = 9;

export async function getStaticPaths() {
	const tagIds = await getTagIds();

	const paths: Array<{ params: { id: string; page: string } }> = [];
	const perPage = 9;

	for (const tagId of tagIds) {
		const filters = buildTagFilters(tagId);
		const res = await getPostCards({ filters, limit: 1, offset: 0 });
		const totalPages = Math.ceil(res.totalCount / perPage);
		for (let page = 2; page <= totalPages; page++) {
			paths.push({ params: { id: encodeURIComponent(tagId), page: String(page) } });
		}
	}

	return paths;
}

const rawIdParam = Astro.params.id;
const pageParam = Astro.params.page;
const page = Number(pageParam);

if (!rawIdParam) throw new Error('Missing route param: id');
if (!Number.isFinite(page) || page < 2) throw new Error(`Invalid page param: ${pageParam}`);

const tagId = decodeURIComponent(rawIdParam);
const tagIdEncoded = encodeURIComponent(tagId);

const tagName = await getTagNameSafe(tagId);

const filters = buildTagFilters(tagId);
const response = await getPostCards({
	filters,
	limit: PER_PAGE,
	offset: (page - 1) * PER_PAGE,
});

const totalPages = Math.ceil(response.totalCount / PER_PAGE);
const posts = response.cards;
---

<BlogPost title={`タグ: ${tagName} (ページ ${page})`} description="andco finance" pubDate={new Date()}>
  <main>
    <ul class="grid">
      {posts.map((post) => {
          return(
            <PostCard
              id={post.id}
              title={post.title}
              eyecatchUrl={post.eyecatchUrl}
              publishedAt={post.publishedAt}
              category={post.categories}
            />
          )
      })}
    </ul>

    <Pagination currentPage={page} totalPages={totalPages} basePath={`/tag/${tagIdEncoded}`} />
  </main>
</BlogPost>

<style>
  main {
    margin: auto;
    padding: 1em;
    width: 1200px;
    max-width: 100%;
  }
  .grid {
    width: stretch;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    padding: 0;
    margin: 0;
  }
  .card-main {
    display: block;
    color: #222;
    text-decoration: none;
    padding: 8px;
    border-radius: 8px;
    background-color: #f0f0f0;
    transition: background-color 0.3s ease;
  }
  .card-main:hover {
    background-color: #e0e0e0;
  }
  .title {
    font-size: 1.2rem;
    font-weight: bold;
    margin: 0;
  }
  .category {
    font-size: 0.85rem;
    color: #444;
    margin: 0.25rem 0 0;
  }
  .meta-link {
    color: inherit;
    text-decoration: underline;
  }
</style>
