---
import BlogPost from "../layouts/BlogPost.astro";
import TableOfContents from "../components/TableOfContents.astro";
import { getBlogDetail, getBlogs } from "../library/microcms";
import type { Blog } from "../library/microcms";

export async function getStaticPaths() {
  const ids: string[] = [];
  let offset = 0;
  const limit = 100;
  while (true) {
    const res = await getBlogs({ fields: ["id"], limit, offset });
    ids.push(...res.contents.map((c) => c.id));
    offset += res.limit;
    if (offset >= res.totalCount) break;
  }
  return ids.map((id) => ({ params: { id } }));
}

const { id } = Astro.params;
if (!id) {
  throw new Error("Missing route param: id");
}

const post: Blog = await getBlogDetail(id, { depth: 1 });

const buildToc = (html: string) => {
  const items: Array<{ id: string; text: string }> = [];
  const strip = (s: string) =>
    s
      .replace(/<[^>]*>/g, "")
      .replace(/\s+/g, " ")
      .trim();

  const withIds = html.replace(/<h2\b([^>]*)>([\s\S]*?)<\/h2>/gi, (full, attrs, inner) => {
    const attrStr = String(attrs ?? "");
    const existingIdMatch = attrStr.match(/\bid\s*=\s*["']([^"']+)["']/i);
    const text = strip(String(inner ?? ""));

    let id = existingIdMatch?.[1];
    if (!id) {
      id = `h2-${items.length + 1}`;
      const attrsWithId = `${attrStr} id="${id}"`;
      items.push({ id, text: text || id });
      return `<h2${attrsWithId}>${inner}</h2>`;
    }

    items.push({ id, text: text || id });
    return full;
  });

  return { html: withIds, items };
};

const { html: contentHtml, items: tocItems } = buildToc(post.content ?? "");

const categories = Array.isArray(post.category)
  ? post.category
  : post.category
  ? [post.category]
  : [];

const tagsRawFromTagsField = Array.isArray(post.tags) ? post.tags : post.tags ? [post.tags] : [];
const tagsRawFromTagField = Array.isArray(post.tag) ? post.tag : post.tag ? [post.tag] : [];

const toTagChip = (t: unknown): { id: string; label: string } | null => {
  if (!t) return null;
  if (typeof t === "string") return { id: t, label: t };
  if (typeof t === "object") {
    const obj = t as { id?: string; name?: string };
    const id = obj.id ?? obj.name;
    if (!id) return null;
    return { id, label: obj.name ?? obj.id ?? id };
  }
  return null;
};

const tags = Array.from(
  new Map(
    [...tagsRawFromTagsField, ...tagsRawFromTagField]
      .map(toTagChip)
      .filter((x): x is { id: string; label: string } => Boolean(x))
      .map((x) => [x.id, x])
  ).values()
);
---

<BlogPost title={post.title} description={post.title} pubDate={new Date()}>
  {post.eyecatch?.url && (
    <div class="hero-image">
      <img
        src={post.eyecatch.url}
        width={post.eyecatch.width}
        height={post.eyecatch.height}
        alt={post.title}
        loading="lazy"
      />
    </div>
  )}
  <TableOfContents items={tocItems} />
  <div class="body" set:html={contentHtml} />

  <section class="footer-meta">
    {categories.length ? (
      <section class="meta">
        <h2 class="meta-title">カテゴリ</h2>
        <ul class="chips">
          {categories.map((cat) => (
            <li>
              <a class="chip" href={`/category/${cat.id}/`}>{cat.name ?? cat.id}</a>
            </li>
          ))}
        </ul>
      </section>
    ) : null}

    {tags.length ? (
      <section class="meta">
        <h2 class="meta-title">タグ</h2>
        <ul class="chips">
          {tags.map((tag) => (
            <li>
              <a class="chip" href={`/tag/${encodeURIComponent(tag.id)}/`}>{tag.label}</a>
            </li>
          ))}
        </ul>
      </section>
    ) : null}
  </section>
</BlogPost>

<style>
  .body :global(img) {
    max-width: 100%;
    height: auto;
  }

  .meta {
    margin-top: 1.5rem;
  }

  .meta-title {
    margin: 0 0 0.5rem;
    font-size: 1rem;
  }

  .chips {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0;
    margin: 0;
  }

  .chip {
    display: inline-block;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    background: #f0f0f0;
    color: #222;
    font-size: 0.85rem;
    text-decoration: none;
  }

  .chip:hover {
    background: #e6e6e6;
  }

  .footer-meta {
    margin-top: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
</style>

