---
export const prerender = false;

import BlogPost from "../../layouts/BlogPost.astro";
import TableOfContents from "../../components/TableOfContents.astro";
import { getPostDetail } from "../../library/cms";

const { id } = Astro.params;
if (!id) throw new Error("Missing route param: id");

const draftKey = Astro.url.searchParams.get("draftKey");
if (!draftKey) {
  Astro.response.status = 400;
}

let post: Awaited<ReturnType<typeof getPostDetail>> | null = null;
try {
  post = await getPostDetail(id, { draftKey });
} catch {
  Astro.response.status = 404;
  post = null;
}

const buildToc = (html: string) => {
  const items: Array<{ id: string; text: string }> = [];
  const strip = (s: string) =>
    s
      .replace(/<[^>]*>/g, "")
      .replace(/\s+/g, " ")
      .trim();

  const withIds = html.replace(/<h2\b([^>]*)>([\s\S]*?)<\/h2>/gi, (full, attrs, inner) => {
    const attrStr = String(attrs ?? "");
    const existingIdMatch = attrStr.match(/\bid\s*=\s*["']([^"']+)["']/i);
    const text = strip(String(inner ?? ""));

    let id = existingIdMatch?.[1];
    if (!id) {
      id = `h2-${items.length + 1}`;
      const attrsWithId = `${attrStr} id="${id}"`;
      items.push({ id, text: text || id });
      return `<h2${attrsWithId}>${inner}</h2>`;
    }

    items.push({ id, text: text || id });
    return full;
  });

  return { html: withIds, items };
};

const { html: contentHtml, items: tocItems } = buildToc(post?.contentHtml ?? "");
const categories = post?.categories ?? [];
const tags = post?.tags ?? [];
---

{post ? (
  <BlogPost title={`[Preview] ${post.title}`} description={post.title} pubDate={new Date()}>
    <TableOfContents items={tocItems} />
    <div class="body" set:html={contentHtml} />

    <section class="footer-meta">
      {categories.length ? (
        <section class="meta">
          <h2 class="meta-title">カテゴリ</h2>
          <ul class="chips">
            {categories.map((cat) => (
              <li>
                <a class="chip" href={`/category/${cat.id}/`}>{cat.name ?? cat.id}</a>
              </li>
            ))}
          </ul>
        </section>
      ) : null}

      {tags.length ? (
        <section class="meta">
          <h2 class="meta-title">タグ</h2>
          <ul class="chips">
            {tags.map((tag) => (
              <li>
                <a class="chip" href={`/tag/${encodeURIComponent(tag.id)}/`}>{tag.label}</a>
              </li>
            ))}
          </ul>
        </section>
      ) : null}
    </section>
  </BlogPost>
) : (
  <BlogPost title="Preview Not Found" description="Preview Not Found" pubDate={new Date()}>
    <div class="body">
      <h1>Not Found</h1>
      <p>下書きプレビューを取得できませんでした。</p>
      {!draftKey ? <p>`draftKey` が付いていません。</p> : null}
    </div>
  </BlogPost>
)}

<style>
  .body :global(img) {
    max-width: 100%;
    height: auto;
  }

  .meta {
    margin-top: 1.5rem;
  }

  .meta-title {
    margin: 0 0 0.5rem;
    font-size: 1rem;
  }

  .chips {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0;
    margin: 0;
  }

  .chip {
    display: inline-block;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    background: #f0f0f0;
    color: #222;
    font-size: 0.85rem;
    text-decoration: none;
  }

  .chip:hover {
    background: #e6e6e6;
  }

  .footer-meta {
    margin-top: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
</style>

