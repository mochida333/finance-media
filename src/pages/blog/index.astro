---
export const prerender = true;

import Pagination from '../../components/Pagination.astro';
import PostCard from '../../components/PostCard.astro';
import { getPostCards } from '../../library/cms';
import BlogPost from '../../layouts/BlogPost.astro';

const PER_PAGE = 9;
const response = await getPostCards({ limit: PER_PAGE, offset: 0 });

const totalPages = Math.ceil(response.totalCount / PER_PAGE);

const posts = response.cards;
---

<BlogPost title="新着記事" description="andco finance" pubDate={new Date()}>
	<ul class="grid">
		{
			posts.map((post) => (
				<PostCard
					id={post.id}
					title={post.title}
					eyecatchUrl={post.eyecatchUrl}
					publishedAt={post.publishedAt}
					category={post.categories}
				/>
			))
		}
	</ul>
	<Pagination currentPage={1} totalPages={totalPages} basePath="/blog" />
</BlogPost>

<style>
	.grid {
		width: stretch;
		list-style: none;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
		padding: 0;
		margin: 0;
	}
	@media (max-width: 720px) {
		.grid {
			grid-template-columns: 1fr;
		}
	}
</style>
