---
import BaseHead from '../../components/BaseHead.astro';
import Pagination from '../../components/Pagination.astro';
import PostCard from '../../components/PostCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getBlogs } from '../../library/microcms';
import BlogPost from '../../layouts/BlogPost.astro';

const PER_PAGE = 9;
const response = await getBlogs({
	fields: ["id", "title", "eyecatch", "publishedAt", "category"],
	depth: 1,
	limit: PER_PAGE,
	offset: 0,
});

const totalPages = Math.ceil(response.totalCount / PER_PAGE);

const posts = response.contents;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				margin: auto;
				padding: 1em;
				width: 1200px;
				max-width: 100%;
				box-sizing: border-box;
			}
			.grid {
				width: stretch;
				list-style: none;
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1rem;
				padding: 0;
				margin: 0;
			}
			@media (max-width: 720px) {
				.grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<BlogPost title="新着記事" description="andco finance" pubDate={new Date()}>
			<main>
				<ul class="grid">
					{
					posts.map((post) => {
						return (
						<PostCard
						id={post.id}
						title={post.title}
						eyecatchUrl={post.eyecatch?.url}
						publishedAt={post.publishedAt}
						category={post.category}
						/>
						);
					})}
				</ul>
				<Pagination currentPage={1} totalPages={totalPages} basePath="/blog" />
			</BlogPost>
		</main>
	</body>
