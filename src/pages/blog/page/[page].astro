---
export const prerender = true;

import Pagination from '../../../components/Pagination.astro';
import PostCard from '../../../components/PostCard.astro';
import { getPostCards } from '../../../library/cms';
import BlogPost from '../../../layouts/BlogPost.astro';

const PER_PAGE = 9;

export async function getStaticPaths() {
	const res = await getPostCards({ limit: 1, offset: 0 });
	const totalPages = Math.ceil(res.totalCount / 9);
	const pages = Array.from({ length: totalPages }, (_, i) => i + 1).filter((p) => p >= 2);
	return pages.map((page) => ({ params: { page: String(page) } }));
}

const pageParam = Astro.params.page;
const page = Number(pageParam);
if (!Number.isFinite(page) || page < 2) {
	throw new Error(`Invalid page param: ${pageParam}`);
}

const offset = (page - 1) * PER_PAGE;

const response = await getPostCards({ limit: PER_PAGE, offset });

const totalPages = Math.ceil(response.totalCount / PER_PAGE);
const posts = response.cards;
---

<BlogPost
	title={`ブログ一覧 (ページ ${page})`}
	description="andco finance"
	pubDate={new Date()}
>
	<ul class="grid">
		{
			posts.map((post) => (
				<PostCard
					id={post.id}
					title={post.title}
					eyecatchUrl={post.eyecatchUrl}
					publishedAt={post.publishedAt}
					category={post.categories}
				/>
			))
		}
	</ul>
	<Pagination currentPage={page} totalPages={totalPages} basePath="/blog" />
</BlogPost>

<style>
	.grid {
		width: stretch;
		list-style: none;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
		padding: 0;
		margin: 0;
	}
	@media (max-width: 720px) {
		.grid {
			grid-template-columns: 1fr;
		}
	}
</style>

