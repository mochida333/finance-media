---
import FormattedDate from "./FormattedDate.astro";
import type { CmsRef } from "../library/cms";

interface Props {
  id: string;
  title: string;
  eyecatchUrl?: string;
  publishedAt?: string;
  category?: CmsRef | CmsRef[];
}

const { id, title, eyecatchUrl, publishedAt, category } = Astro.props as Props;

const categories = Array.isArray(category) ? category : category ? [category] : [];
const href = `/${id}/`;
---

<li class="post-card">
  <a class="main" href={href}>
    {eyecatchUrl ? <img class="image" src={eyecatchUrl} alt={title} /> : null}
    <h3 class="title">{title}</h3>
    {publishedAt ? <FormattedDate date={new Date(publishedAt)} /> : null}
  </a>

  {categories.length ? (
    <p class="category">
      {categories.map((c, idx) => (
        <>
          {idx ? ", " : ""}
          <a class="category-link" href={`/category/${c.id}/`}>
            {c.name ?? c.id}
          </a>
        </>
      ))}
    </p>
  ) : null}
</li>

<style>
  .post-card {
    list-style: none;
  }

  .main {
    display: block;
    color: #222;
    text-decoration: none;
    padding: 8px;
    border-radius: 8px;
    background-color: #f0f0f0;
    transition: background-color 0.3s ease;
  }

  .main:hover {
    background-color: #e0e0e0;
  }

  .image {
    width: 100%;
    height: auto;
    border-radius: 8px;
    display: block;
  }

  .title {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0.5rem 0 0;
    padding-left: 0;
    line-height: 1.3;
    border: none;
  }

  :global(.date) {
    display: block;
    font-size: 0.85rem;
    color: #666;
    margin-top: 0.25rem;
  }

  .category {
    font-size: 0.85rem;
    color: #444;
    margin: 0.25rem 0 0;
  }

  .category-link {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  @media (max-width: 768px) {
    .main {
      padding: 10px;
    }

    .title {
      font-size: 1rem;
    }

    :global(.date) {
      font-size: 0.8rem;
    }

    .category {
      font-size: 0.8rem;
    }
  }
</style>

